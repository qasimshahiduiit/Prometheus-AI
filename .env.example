# Copy this file to .env.local and fill in your own values.
# In Vercel, set these as Project → Settings → Environment Variables.
# Anything WITHOUT the NEXT_PUBLIC_ prefix is server-only — never expose it.

# ─── Supabase · auth + database + storage ───────────────
# Project URL and the public (publishable / anon) key are safe to expose.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SECRET — server only. Used for all DB + Storage access; bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=

# ─── OpenCode Zen · primary text model ──────────────────
OPENCODE_API_KEY=
OPENCODE_BASE_URL=https://opencode.ai/zen/v1
OPENCODE_MODEL=big-pickle

# ─── Google AI Studio · vision/PDF (used when files attached) ───
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-3.1-flash-lite

# ─── Tavily · web search ────────────────────────────────
TAVILY_API_KEY=

# ─── Cloudflare Workers AI · image generation (flux) ────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_IMAGE_MODEL=@cf/black-forest-labs/flux-2-klein-4b

# ─── Groq · welcome-screen suggestion cards ─────────────
GROQ_API_KEY=
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
